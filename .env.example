# ===========================================
# CyberAngel Portal - Environment Variables
# ===========================================
# Copy this file to backend/.env and fill in values

# Server Port (deployment platforms set this automatically)
PORT=3000

# ---- OpenAI (for AI Scam Scanner & Chatbot) ----
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ---- Firebase (for database & authentication) ----
# Option 1: Set project ID + place serviceAccountKey.json in backend/
FIREBASE_PROJECT_ID=cyberangle

# Option 2: For deployment platforms, paste the ENTIRE service account JSON as a single line:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"cyberangle",...}

# ---- Security ----
JWT_SECRET=change-this-to-a-random-string

# ---- CORS ----
CORS_ORIGIN=*

# ---- Node Environment ----
NODE_ENV=production
